<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">
        <Label Text="MauiAppHotel" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" />

        <Label Text="Desenvolvido por Michael" HorizontalOptions="Center" TextColor="Black" />
        <Label Text="2026" HorizontalOptions="Center" TextColor="Black"/>

        <BoxView HeightRequest="1" Color="{StaticResource Primary}" />

        <Label Text="Aplicativo para projeto de estudos em desenvolvimento mobile utilizando .NET MAUI." 
               HorizontalTextAlignment="Center"
               TextColor="Black"/>

    </VerticalStackLayout>
</ContentPage>